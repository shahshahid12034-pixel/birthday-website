<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday Bro 🎉</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: linear-gradient(to top, #1e1e2f, #3a3a5f);
    text-align: center;
    overflow-x: hidden;
    color: white;
}

/* Title */
h1 {
    font-size: 2.5em;
    margin-top: 30px;
}

/* Image */
img.main {
    width: 80%;
    max-width: 300px;
    border-radius: 20px;
    margin-top: 20px;
}

/* Cake */
.cake {
    margin: 30px auto;
    width: 150px;
    height: 100px;
    background: pink;
    border-radius: 10px;
    position: relative;
}

.candle {
    width: 8px;
    height: 30px;
    background: white;
    position: absolute;
    top: -30px;
    left: 50%;
    transform: translateX(-50%);
}

.flame {
    width: 8px;
    height: 8px;
    background: orange;
    border-radius: 50%;
    position: absolute;
    top: -8px;
    animation: flicker 0.4s infinite;
}

@keyframes flicker {
    0% { transform: scale(1); }
    50% { transform: scale(1.3); }
    100% { transform: scale(1); }
}

/* Balloons */
.balloon {
    position: fixed;
    bottom: -100px;
    width: 30px;
    height: 40px;
    border-radius: 50%;
    animation: floatUp linear infinite;
}

@keyframes floatUp {
    to { transform: translateY(-120vh); }
}

/* Button */
button {
    padding: 12px 20px;
    border: none;
    border-radius: 25px;
    background: linear-gradient(to right, orange, pink);
    color: white;
    font-size: 16px;
    margin: 10px;
}

/* Message */
.message {
    padding: 20px;
    font-size: 1.1em;
}
</style>
</head>

<body>

<h1>🎉 Happy Birthday Bro 🎉</h1>

<img src="https://picsum.photos/300" class="main">

<div class="cake">
    <div class="candle">
        <div class="flame"></div>
    </div>
</div>

<button onclick="playMusic()">Play Music 🎵</button>

<div class="message">
    Bro, you're not just a friend — you're family ❤️ <br>
    Stay crazy, stay real, and keep shining 🔥
</div>

<audio id="music" src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"></audio>

<script>
function playMusic() {
    document.getElementById("music").play();
}

/* Balloons */
for (let i = 0; i < 15; i++) {
    let b = document.createElement("div");
    b.className = "balloon";
    b.style.left = Math.random() * 100 + "vw";
    b.style.background = `hsl(${Math.random()*360},70%,60%)`;
    b.style.animationDuration = (4 + Math.random()*3) + "s";
    document.body.appendChild(b);
}
</script>

</body>
</html>
